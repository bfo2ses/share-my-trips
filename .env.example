# Required
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Optional — adjust to match your NAS setup
# PORT=80
# CORS_ORIGIN=http://your-nas-ip
# RESET_URL_BASE=http://your-nas-ip/reset-password

# SMTP — leave empty to use log mailer (prints reset links to stdout)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_FROM=noreply@example.com
# SMTP_USERNAME=
# SMTP_PASSWORD=
